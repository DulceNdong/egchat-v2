{
  "name": "egchat-backend",
  "version": "2.0.0",
  "description": "EGCHAT Backend - Complete Enterprise Platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "deploy": "git add . && git commit -m 'Deploy EGCHAT Backend v2.0.0' && git push origin main"
  },
  "keywords": ["egchat", "messaging", "fintech", "guinea-ecuatorial", "cemac"],
  "author": "EGCHAT Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "@supabase/supabase-js": "^2.38.4",
    "multer": "^1.4.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/egchat/backend.git"
  },
  "bugs": {
    "url": "https://github.com/egchat/backend/issues"
  },
  "homepage": "https://egchat-app.vercel.app",
  "deployment": {
    "render": {
