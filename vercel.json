{
  "framework": "vite",
  "buildCommand": "npm run build:pwa",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!api).*)", "destination": "/index.html" }],
  "env": {
    "VITE_API_URL": "/api",
    "VITE_APP_URL": "https://egchat-app.vercel.app",
    "VITE_BUILD_VERSION": "20260411-0001"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/logo-transparent.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0"
        }
      ]
    }
  ]
}
